{
	"name": "web-scraper",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "bun src/index.ts",
		"start": "bun src/index.ts",
		"build": "bun run --cwd client build",
		"app": "bun run build && bun run start",
		"typecheck": "bunx tsc --noEmit",
		"test": "bun test",
		"check": "bun run typecheck && bun test"
	},
	"dependencies": {
		"@mozilla/readability": "^0.6.0",
		"hono": "^4.12.18",
		"jsdom": "^29.1.1",
		"turndown": "^7.2.4",
		"turndown-plugin-gfm": "^1.0.2"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/jsdom": "^28.0.3",
		"@types/turndown": "^5.0.6",
		"typescript": "^6.0.3"
	}
}
