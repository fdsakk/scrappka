PORT=3000

# Basic auth (optional). When AUTH_PASSWORD is set, all routes require credentials.
# AUTH_USERNAME=admin
# AUTH_PASSWORD=

# Storage
SCRAPED_DIR=./scraped_data

# Scraper tuning (all optional)
# SCRAPER_UA="Mozilla/5.0 (compatible; WebScrapperBot/0.1)"
# SCRAPER_TIMEOUT_MS=15000
# SCRAPER_CRAWL_CONCURRENCY=5
# SCRAPER_DISCOVER_BATCH=25
# SCRAPER_DISCOVER_LIMIT=5000
# SCRAPER_MAX_BYTES=10000000
# SCRAPER_STALL_TIMEOUT_MS=120000
# SCRAPE_CONCURRENCY=8
